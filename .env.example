# =============================================================================
# NotiPush - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# On the VPS, place .env next to docker-compose.prod.yml
# =============================================================================

# --- Docker Hub ---
DOCKER_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# --- Database ---
DB_USER=notipush
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=notipush

# --- Domain ---
DOMAIN=notipush.createam.io
DOMAIN_API=notipush-api.createam.io

# --- Exposed Ports (host:container mapping) ---
# Change if these ports are already in use on the VPS
API_PORT_EXT=8050
WEB_PORT_EXT=3050

# --- Worker ---
WORKER_CONCURRENCY=10

# --- VAPID Keys (generate with: go run ./cmd/vapidgen OR see README) ---
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CONTACT=mailto:admin@yourdomain.com

# --- Admin Secret ---
# Protects admin endpoints (create/list projects).
# The same value is used by the Go API and injected server-side by Next.js.
# Generate with: openssl rand -base64 32
ADMIN_SECRET=

# --- Next.js / Frontend ---
# Internal URL used by Next.js API proxy (Docker network, never exposed to browser).
# In Docker Compose this is http://api:8080 — do NOT change unless you know what you're doing.
# API_URL_INTERNAL is set automatically in docker-compose.prod.yml

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://notipush.createam.io

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Security ---
# Secret for /admin endpoints. Generate with: openssl rand -base64 32
# Leave empty in dev to skip auth.
ADMIN_SECRET=

# Allowed CORS origins (comma-separated). Must include the frontend domain.
CORS_ORIGINS=https://notipush.createam.io
