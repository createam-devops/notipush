# =============================================================================
# NotiPush - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# On the VPS, place .env next to docker-compose.prod.yml
# =============================================================================

# --- Docker Hub ---
DOCKER_USERNAME=your-dockerhub-username
IMAGE_TAG=latest

# --- Database ---
DB_USER=notipush
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_NAME=notipush

# --- Domain (used by Caddy for automatic HTTPS) ---
DOMAIN=notipush.createam.io
DOMAIN_API=notipush-api.createam.io

# --- Ports (only if running without Caddy) ---
API_PORT=8080
WEB_PORT=3000

# --- Worker ---
WORKER_CONCURRENCY=10

# --- VAPID Keys (generate with: go run ./cmd/vapidgen OR see README) ---
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CONTACT=mailto:admin@yourdomain.com

# --- Next.js / Frontend ---
# URL where the Go API is reachable from the browser (the API subdomain).
NEXT_PUBLIC_API_URL=https://notipush-api.createam.io

# --- NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://notipush.createam.io

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Security ---
# Secret for /admin endpoints. Generate with: openssl rand -base64 32
# Leave empty in dev to skip auth.
ADMIN_SECRET=

# Allowed CORS origins (comma-separated). Must include the frontend domain.
CORS_ORIGINS=https://notipush.createam.io
